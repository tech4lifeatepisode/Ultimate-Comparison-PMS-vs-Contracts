OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL_DEFAULT=gpt-5.2-2025-12-11

# Supabase (Project Settings > API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Prefer service_role JWT for Storage uploads (bypasses RLS). New sb_secret_* may work; if not, paste legacy service_role key from Dashboard.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: if set, used for DB when SERVICE_ROLE is empty
SUPABASE_SECRET_KEY=

# Bucket id must match public URLs: .../object/public/<BucketId>/...
SUPABASE_STORAGE_BUCKET=Contracts

# Folder prefix inside the bucket (can contain spaces).
SUPABASE_STORAGE_FOLDER=To Fill 1

# Optional: comma- or newline-separated public URLs if listing the bucket returns no files (RLS / name mismatch).
# CONTRACT_PUBLIC_URLS=https://....supabase.co/storage/v1/object/public/Contracts/To%20Fill%201/file.pdf

# Cap how many objects to download per run (large folders). Omit for no limit.
MAX_EXTRACTION_FILES=10

# Skip storage paths already present in contract_extractions.file_name (needed for batch runs).
# Set to false to re-process from the start of the sorted list (still capped by MAX_EXTRACTION_FILES).
# Truthy: true, 1, yes, on (case-insensitive). Requires DB SELECT on file_name (anon policy in supabase-schema.sql or service_role key).
# Empty table: 0 rows skipped — batch 1 still starts at the first file; keep true so batch 2+ advances.
SKIP_ALREADY_EXTRACTED=true

# Retries per file on 502/503 (default 4).
# STORAGE_DOWNLOAD_RETRIES=4

# Render: on each deploy/boot, run ALL pending batches until the folder is done (not just MAX_EXTRACTION_FILES).
# Also use POST/GET /extract-all for the same without redeploying. Single batch: /extract
AUTO_EXTRACT_FROM_STORAGE=false

# Optional: require this header for /extract and /extract-all (X-Extract-Secret)
EXTRACT_TRIGGER_SECRET=

# Optional: set true to skip second API pass when dates/rent/deposit unknown or CHAMARI name (saves cost; weaker extraction)
# EXTRACTION_SKIP_REFINEMENT_PASS=false
