OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL_DEFAULT=gpt-5.2-2025-12-11

# Supabase (Project Settings > API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Prefer service_role JWT for Storage uploads (bypasses RLS). New sb_secret_* may work; if not, paste legacy service_role key from Dashboard.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: if set, used for DB when SERVICE_ROLE is empty
SUPABASE_SECRET_KEY=

# Bucket id must match public URLs: .../object/public/<BucketId>/...
SUPABASE_STORAGE_BUCKET=Contracts

# Folder prefix inside the bucket (can contain spaces).
SUPABASE_STORAGE_FOLDER=HouseMonk Sample Contracts

# Optional: comma- or newline-separated public URLs if listing the bucket returns no files (RLS / name mismatch).
# CONTRACT_PUBLIC_URLS=https://....supabase.co/storage/v1/object/public/Contracts/HouseMonk%20Sample%20Contracts/file.pdf

# Render: set true to download PDFs from Storage folder above and insert into DB on each deploy/boot
AUTO_EXTRACT_FROM_STORAGE=false

# Optional: require this header for POST /extract or GET /extract (X-Extract-Secret)
EXTRACT_TRIGGER_SECRET=
